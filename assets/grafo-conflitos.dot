graph G {
  graph [
    layout=neato,
    bgcolor="white",
    outputorder=edgesfirst,
    splines=true,
    overlap=false,
    pad=0.25
  ];

  node [
    shape=circle,
    style="filled",
    fillcolor="#f8fafc",
    color="#334155",
    fontname="Helvetica",
    fontsize=18,
    width=0.55,
    height=0.55,
    fixedsize=true
  ];

  edge [
    color="#475569",
    penwidth=2
  ];

  A [pos="0,300!"];
  B [pos="-180,0!"];
  C [pos="180,0!"];
  D [pos="0,125!"];
  E [pos="-70,45!"];
  F [pos="70,45!"];

  A -- B;
  A -- C;
  A -- D;
  B -- C;
  B -- D;
  B -- E;
  C -- D;
  C -- F;
  D -- E;
  D -- F;
  E -- F;
}
